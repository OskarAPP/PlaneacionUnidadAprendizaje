<!DOCTYPE html PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN" "http://www.w3.org/TR/html4/loose.dtd">
<html>
<head>
    <link rel="stylesheet" href="css/estilo.css" type="text/css"/>
	
	<link rel="stylesheet" href="css/bootstrap.min.css" type="text/css"/>
	<link rel="stylesheet" href="css/select2.min.css" type="text/css"/>
	<link rel="stylesheet" href="css/animate.css" type="text/css" />
	<link rel="shortcut icon" href="images/uac.png">

	<script src="js/jquery-2.1.4.min.js" type="text/javascript"></script>
	<script src="js/bootstrap.min.js" type="text/javascript"></script>
	<script src="js/select2.min.js" type="text/javascript"></script>
	<script src="js/funcionesCRUD.js" type="text/javascript"></script>
	<script src="js/funcionesGUI.js" type="text/javascript"></script>
	
</head>
    
	<body style="background-color: rgb(115, 115, 115);">

	
	
	<div class="container">	
	
	
		<div class="menu-principal animated zoomIn">
			
			<div class="row">
				<div class="col-lg-6 animated bounceInLeft">
					<img alt="" src="images/uac_pua_inverse.png">
				</div>
			</div>
			
			<form action="ProcesarLogin.action" method="post" >	
			<div class="row">
				<div class="col-lg-6 animated bounceInLeft">
					<label for="usuarioCampo">Usuario:</label>
					<div class='form-group' >										
						<input type='text' class="form-control" id='usuarioCampo' name="usuarioCampo"/>										
	            	</div> 
				</div>
			</div>
			
			<div class="row">
				<div class="col-lg-6 animated bounceInLeft">
					<label for="passwordCampo">Pass:</label>
						<div class='form-group' >										
							<input type="password" class="form-control" id='passwordCampo' name="passwordCampo"/>										
	            		</div>
				</div>
			</div>
			
			<div class="row">
				<div class="col-lg-6 animated bounceInLeft">
					<div class="form-group">								
	    				<button type="submit"  class="form-control btn btn-default">Entrar</button>
	    			</div>
				</div>
			</div>
			
			</form>
			 
			 <div class="row">
	    	 	<div class="col-md-6">
	    			#if($mensaje)
	              		<div class="alert alert-danger">
	               			<strong>Fallo!</strong> $mensaje
	               		</div>
	               	#end	
	    		</div>
	          </div>
		</div>
		
			
	
</body>
	
</html>